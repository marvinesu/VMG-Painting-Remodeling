# ============ Website app (Astro) environment variables ============
# All values are server-only. NEVER prefix secrets with ASTRO_PUBLIC_.

# --- Payload CMS connection (server-to-server) ---
# REST API base URL of the CMS app, e.g. https://cms.vmgpaintingnremodelingllc.com/api
PAYLOAD_INTERNAL_API_URL=
# Public URL of the CMS (used for media file URLs in rendered content)
PAYLOAD_PUBLIC_SERVER_URL=
# API key of an admin user in the CMS (Users -> enable API key)
PAYLOAD_API_KEY=

# --- SMTP password encryption (must match the CMS app's value) ---
SMTP_ENCRYPTION_KEY=

# --- SMTP fallback (used when CMS SMTP settings are disabled/unavailable) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@vmgpaintingnremodelingllc.com
SMTP_PASS=
SMTP_FROM=info@vmgpaintingnremodelingllc.com
LEAD_NOTIFY_EMAIL=vmgpaintingnremodelingllc@gmail.com

# --- Hostinger Node runtime ---
HOST=0.0.0.0

# --- Public (client-visible) values only below this line ---
ASTRO_PUBLIC_SITE_URL=https://vmgpaintingnremodelingllc.com
