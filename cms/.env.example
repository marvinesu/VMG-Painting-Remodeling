# Payload CMS environment variables (server-only — never commit real values)

# Long random string used to sign auth tokens. Generate e.g. with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=

# Public URL of this CMS app (used by the admin UI and media URLs)
PAYLOAD_PUBLIC_SERVER_URL=https://cms.vmgpaintingnremodelingllc.com

# SQLite database file (default). For Postgres, switch the adapter in payload.config.ts.
DATABASE_URI=file:./vmg-cms.db

# Shared AES-256-GCM key for the SMTP password (must match the Astro app's value)
SMTP_ENCRYPTION_KEY=
