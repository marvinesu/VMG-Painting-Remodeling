---
/**
 * Lightweight estimate CTA — a plain link, zero JavaScript.
 * Used in the header; the full native estimate form lives on /free-estimate.
 */
interface Props {
  className?: string;
}
const { className = "" } = Astro.props;
---
<div class={`estimate-cta ${className}`}>
  <a class="btn" href="/free-estimate">Request a Free Estimate</a>
</div>

<style>
  .estimate-cta {
    display: inline-flex;
    width: fit-content;
  }
</style>
