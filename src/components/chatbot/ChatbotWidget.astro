---
/**
 * Native VMG chat assistant — no external chatbot provider, no heavy
 * libraries. A small vanilla-JS guided flow that collects the same lead
 * information as the estimate form and POSTs the complete transcript to /api/chat.
 *
 * To change questions/options, edit the `config` object below (options come
 * from src/lib/leadOptions.ts so forms and chatbot stay in sync).
 */
import {
  BUDGET_OPTIONS,
  CONTACT_METHOD_OPTIONS,
  COUNTY_OPTIONS,
  OWNER_OPTIONS,
  SERVICE_OPTIONS,
  TIMELINE_OPTIONS
} from "../../lib/leadOptions";
import { services } from "../../data/services";
import { site } from "../../data/site";

const config = {
  phoneDisplay: site.phoneDisplay,
  tel: site.tel,
  email: site.email,
  services: SERVICE_OPTIONS,
  counties: COUNTY_OPTIONS,
  timelines: TIMELINE_OPTIONS,
  budgets: BUDGET_OPTIONS,
  owners: OWNER_OPTIONS,
  contactMethods: CONTACT_METHOD_OPTIONS,
  servicePages: services.map((service) => ({ label: service.title, href: `/services/${service.slug}` }))
};
---
<div class="vmg-chat" data-chat data-config={JSON.stringify(config)}>
  <button class="chat-launcher" type="button" aria-expanded="false" aria-controls="vmg-chat-panel" data-chat-launcher>
    <svg aria-hidden="true" width="19" height="19" viewBox="0 0 24 24" fill="currentColor">
      <path d="M20 2H4a2 2 0 0 0-2 2v18l4-4h14a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zM7 9h10v2H7V9zm6 5H7v-2h6v2zm4-6H7V6h10v2z"/>
    </svg>
    <span>Chat with us</span>
  </button>

  <section id="vmg-chat-panel" class="chat-panel" role="dialog" aria-label="VMG Painting & Remodeling chat assistant" hidden data-chat-panel>
    <header class="chat-header">
      <div class="chat-identity">
        <span class="chat-avatar" aria-hidden="true">V</span>
        <div class="chat-titles">
          <p class="chat-title">VMG Assistant</p>
          <p class="chat-subtitle">Free estimates &middot; Roy, WA</p>
        </div>
      </div>
      <div class="chat-header-actions">
        <button type="button" class="chat-icon-button" data-chat-restart aria-label="Restart conversation" title="Start over">
          <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12a9 9 0 1 0 2.6-6.4L3 8" /><path d="M3 3v5h5" />
          </svg>
        </button>
        <button type="button" class="chat-icon-button" data-chat-close aria-label="Close chat" title="Close">
          <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
            <path d="M5 5l14 14M19 5L5 19" />
          </svg>
        </button>
      </div>
    </header>
    <div class="chat-messages" data-chat-messages aria-live="polite"></div>
    <div class="chat-options" data-chat-options></div>
    <form class="chat-input-row" data-chat-input-row hidden>
      <label class="visually-hidden" for="vmg-chat-input">Your answer</label>
      <input id="vmg-chat-input" type="text" autocomplete="off" placeholder="Type your answer…" />
      <label class="visually-hidden" for="vmg-chat-textarea">Your message</label>
      <textarea id="vmg-chat-textarea" rows="3" hidden placeholder="Tell us about your project"></textarea>
      <button class="btn chat-send" type="submit">Send</button>
    </form>
  </section>
</div>

<script>
  const root = document.querySelector<HTMLElement>("[data-chat]");

  if (root) {
    const config = JSON.parse(root.dataset.config ?? "{}");
    const launcher = root.querySelector<HTMLButtonElement>("[data-chat-launcher]")!;
    const panel = root.querySelector<HTMLElement>("[data-chat-panel]")!;
    const messagesEl = root.querySelector<HTMLElement>("[data-chat-messages]")!;
    const optionsEl = root.querySelector<HTMLElement>("[data-chat-options]")!;
    const inputRow = root.querySelector<HTMLFormElement>("[data-chat-input-row]")!;
    const inputEl = inputRow.querySelector<HTMLInputElement>("input")!;
    const textareaEl = inputRow.querySelector<HTMLTextAreaElement>("textarea")!;
    const closeButton = root.querySelector<HTMLButtonElement>("[data-chat-close]")!;
    const restartButton = root.querySelector<HTMLButtonElement>("[data-chat-restart]")!;

    type Step = {
      key: string;
      label: string;
      question: string;
      options?: string[];
      input?: boolean;
      multiline?: boolean;
      validate?: "phone" | "email";
    };

    const ESTIMATE_STEPS: Step[] = [
      { key: "service", label: "Service", question: "What type of project do you need help with?", options: config.services },
      { key: "county", label: "County", question: "Where is the project located?", options: config.counties },
      { key: "location", label: "Address / City", question: "What is the project address or city?", input: true },
      { key: "details", label: "Project Description", question: "Tell us a little about the project.", input: true, multiline: true },
      { key: "timeline", label: "Timeline", question: "When would you like to start?", options: config.timelines },
      { key: "budget", label: "Budget", question: "What is your approximate budget?", options: config.budgets },
      { key: "owner", label: "Property Owner", question: "Are you the property owner?", options: config.owners },
      { key: "name", label: "Name", question: "What is your full name?", input: true },
      { key: "phone", label: "Phone", question: "What is the best phone number to reach you?", input: true, validate: "phone" },
      { key: "email", label: "Email", question: "What is your email address?", input: true, validate: "email" },
      { key: "contactMethod", label: "Contact Method", question: "How would you prefer we contact you?", options: config.contactMethods }
    ];

    const QUESTION_STEPS: Step[] = [
      { key: "details", label: "Question", question: "What would you like to ask our team?", input: true, multiline: true },
      { key: "name", label: "Name", question: "What is your full name?", input: true },
      { key: "phone", label: "Phone", question: "What is the best phone number to reach you?", input: true, validate: "phone" },
      { key: "email", label: "Email", question: "What is your email address?", input: true, validate: "email" },
      { key: "contactMethod", label: "Contact Method", question: "How would you prefer we contact you?", options: config.contactMethods }
    ];

    const CONSENT_QUESTION =
      "Do you agree to be contacted by VMG Painting & Remodeling LLC by phone, text, or email regarding your request? Message and data rates may apply.";

    let steps: Step[] = [];
    let stepIndex = 0;
    let answers: Record<string, string> = {};
    let leadType = "Chatbot Estimate Request";
    let editingKey: string | null = null;
    let opened = false;
    // Full transcript + session id, submitted to /api/chat for CMS storage.
    let transcript: { sender: "user" | "bot"; text: string; timestamp: string }[] = [];
    let sessionId = "";
    let conversationVersion = 0;
    let submitting = false;

    function newSessionId(): string {
      return typeof crypto !== "undefined" && "randomUUID" in crypto
        ? crypto.randomUUID()
        : `chat-${Date.now()}-${Math.random().toString(16).slice(2)}`;
    }

    function isValidEmail(value: string) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(value);
    }
    function isValidPhone(value: string) {
      const digits = value.replace(/\D/g, "");
      return digits.length === 10 || (digits.length === 11 && digits.startsWith("1"));
    }

    function addMessage(kind: "bot" | "user", html: string) {
      const bubble = document.createElement("div");
      bubble.className = `chat-msg ${kind}`;
      bubble.innerHTML = html;
      if (bubble.querySelector(".chat-summary")) bubble.classList.add("summary");
      messagesEl.appendChild(bubble);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      transcript.push({ sender: kind, text: bubble.textContent ?? "", timestamp: new Date().toISOString() });
    }

    function botSay(html: string, done?: () => void) {
      const version = conversationVersion;
      const typing = document.createElement("div");
      typing.className = "chat-msg bot chat-typing";
      typing.textContent = "…";
      messagesEl.appendChild(typing);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      window.setTimeout(() => {
        if (version !== conversationVersion) {
          typing.remove();
          return;
        }
        typing.remove();
        addMessage("bot", html);
        done?.();
      }, 350);
    }

    function escapeHtml(value: string) {
      return value.replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;");
    }

    function clearOptions() {
      optionsEl.innerHTML = "";
      inputRow.hidden = true;
    }

    function showOptions(items: { label: string; onSelect?: () => void; href?: string }[]) {
      clearOptions();
      items.forEach((item) => {
        if (item.href) {
          const link = document.createElement("a");
          link.className = "chat-option";
          link.href = item.href;
          link.textContent = item.label;
          optionsEl.appendChild(link);
        } else {
          const button = document.createElement("button");
          button.type = "button";
          button.className = "chat-option";
          button.textContent = item.label;
          button.addEventListener("click", () => item.onSelect?.());
          optionsEl.appendChild(button);
        }
      });
      optionsEl.querySelector<HTMLElement>(".chat-option")?.focus();
    }

    function showInput(step: Step) {
      clearOptions();
      inputRow.hidden = false;
      inputEl.value = "";
      textareaEl.value = "";
      inputEl.hidden = Boolean(step.multiline);
      textareaEl.hidden = !step.multiline;
      inputEl.placeholder = "Type your answer…";
      inputRow.dataset.stepKey = step.key;
      inputEl.placeholder = step.key === "phone" ? "(253) 754-4871" : step.key === "email" ? "you@example.com" : "Type your answer";
      textareaEl.placeholder = leadType.includes("Estimate")
        ? "Example: exterior repaint, roof repair, new deck, siding replacement, kitchen remodel"
        : "Type your message";
      (step.multiline ? textareaEl : inputEl).focus();
    }

    function start() {
      messagesEl.innerHTML = "";
      answers = {};
      steps = [];
      stepIndex = 0;
      editingKey = null;
      transcript = [];
      sessionId = newSessionId();
      conversationVersion += 1;
      submitting = false;
      botSay(
        "Hi! I'm the VMG Assistant. I can help you request a free estimate, ask a question, or connect with our team. What would you like to do?",
        showMainMenu
      );
    }

    function showMainMenu() {
      showOptions([
        { label: "Request a Free Estimate", onSelect: () => beginFlow(ESTIMATE_STEPS, "Chatbot Estimate Request", "Request a Free Estimate") },
        { label: "Ask a Question", onSelect: () => beginFlow(QUESTION_STEPS, "Chatbot General Question", "Ask a Question") },
        { label: "View Services", onSelect: showServices },
        { label: "Call VMG Now", onSelect: showCallNow }
      ]);
    }

    function showCallNow() {
      addMessage("user", "Call VMG Now");
      botSay(
        `You can call VMG Painting &amp; Remodeling at <a href="tel:${config.tel}"><strong>${config.phoneDisplay}</strong></a>.`,
        () => showOptions([
          { label: `Call ${config.phoneDisplay}`, href: `tel:${config.tel}` },
          { label: "Back to menu", onSelect: showMainMenu }
        ])
      );
    }

    function showServices() {
      addMessage("user", "View Services");
      botSay("Choose a service to view details or start a free estimate:", () => {
        const items = config.servicePages.map((page: { label: string; href: string }) => ({
          label: page.label,
          onSelect: () => showServiceChoice(page)
        }));
        items.push({ label: "Request a Free Estimate", onSelect: () => beginFlow(ESTIMATE_STEPS, "Chatbot Estimate Request", "Request a Free Estimate") } as never);
        items.push({ label: "Back to menu", onSelect: showMainMenu } as never);
        showOptions(items);
      });
    }

    function showServiceChoice(page: { label: string; href: string }) {
      addMessage("user", escapeHtml(page.label));
      botSay(`Would you like to learn more about ${escapeHtml(page.label)} or request a free estimate?`, () =>
        showOptions([
          { label: `View ${page.label}`, href: page.href },
          { label: "Request an Estimate", onSelect: () => beginFlow(ESTIMATE_STEPS, "Chatbot Estimate Request", `Estimate for ${page.label}`) },
          { label: "Back to Services", onSelect: showServices }
        ])
      );
    }

    function beginFlow(flowSteps: Step[], type: string, userLabel: string) {
      addMessage("user", escapeHtml(userLabel));
      steps = flowSteps.map((step) => ({ ...step, options: step.options ? [...step.options] : undefined }));
      leadType = type;
      stepIndex = 0;
      editingKey = null;
      askCurrent();
    }

    function askCurrent() {
      const step = steps[stepIndex];
      if (!step) {
        askConsent();
        return;
      }
      botSay(escapeHtml(step.question), () => {
        if (step.options) {
          showOptions(step.options.map((option: string) => ({ label: option, onSelect: () => answer(step, option) })));
        } else {
          showInput(step);
        }
      });
    }

    function answer(step: Step, value: string) {
      addMessage("user", escapeHtml(value));
      answers[step.key] = value;
      if (step.key === "county" && value !== "Other") {
        delete answers.otherCounty;
        steps = steps.filter((item) => item.key !== "otherCounty");
      }
      if (step.key === "county" && value === "Other" && !steps.some((item) => item.key === "otherCounty")) {
        steps.splice(stepIndex + 1, 0, { key: "otherCounty", label: "County / City", question: "What county or city is the project in?", input: true });
      }
      if (step.key === "owner" && value !== "Yes" && !steps.some((item) => item.key === "ownerRelationship")) {
        steps.splice(stepIndex + 1, 0, { key: "ownerRelationship", label: "Relationship to Owner", question: "What is your relationship to the property owner?", input: true });
      }
      if (step.key === "owner" && value === "Yes") {
        delete answers.ownerRelationship;
        steps = steps.filter((item) => item.key !== "ownerRelationship");
      }
      if (editingKey) {
        editingKey = null;
        showSummary();
        return;
      }
      stepIndex += 1;
      askCurrent();
    }

    function askConsent() {
      botSay(escapeHtml(CONSENT_QUESTION), () =>
        showOptions([
          { label: "Yes, I agree", onSelect: () => { addMessage("user", "Yes, I agree"); answers.consent = "true"; showSummary(); } },
          { label: "No", onSelect: () => {
            addMessage("user", "No");
            answers.consent = "";
            botSay(
              `No problem. You can still call us directly at <a href="tel:${config.tel}"><strong>${config.phoneDisplay}</strong></a>.`,
              () => showOptions([{ label: "Back to menu", onSelect: showMainMenu }])
            );
          } }
        ])
      );
    }

    function showSummary() {
      const rows = steps
        .filter((step) => answers[step.key])
        .map((step) => `<div class="summary-row"><dt>${escapeHtml(step.label)}</dt><dd>${escapeHtml(answers[step.key])}</dd></div>`)
        .join("");
      botSay(`<section class="chat-summary"><h3>Review Your Request</h3><dl>${rows}</dl></section>`, () =>
        showOptions([
          { label: "Submit Request", onSelect: submitLead },
          { label: "Edit Information", onSelect: showEditMenu },
          { label: "Start Over", onSelect: start }
        ])
      );
    }

    function showEditMenu() {
      addMessage("user", "Edit Information");
      botSay("Which answer would you like to change?", () =>
        showOptions([
          ...steps
            .filter((step) => answers[step.key] !== undefined)
            .map((step) => ({
              label: step.label,
              onSelect: () => {
                editingKey = step.key;
                stepIndex = steps.findIndex((item) => item.key === step.key);
                askCurrent();
              }
            })),
          { label: "Back to summary", onSelect: showSummary }
        ])
      );
    }

    async function submitLead() {
      if (submitting) return;
      submitting = true;
      addMessage("user", "Submit Request");
      clearOptions();
      panel.setAttribute("aria-busy", "true");
      botSay("Sending your request…");
      try {
        const response = await fetch("/api/chat", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            sessionId,
            leadType,
            messages: transcript,
            ...answers,
            serviceNeeded: answers.service,
            projectAddressOrCity: answers.location,
            projectDescription: answers.details,
            propertyOwner: answers.owner,
            ownerRelationship: answers.ownerRelationship,
            preferredContactMethod: answers.contactMethod,
            sourcePage: location.pathname,
            submittedAt: new Date().toISOString(),
            page: location.pathname
          })
        });
        const result = await response.json().catch(() => ({}));
        if (response.ok && result.ok) {
          botSay(
            `Thank you! Your request has been sent to VMG Painting &amp; Remodeling. Our team will contact you shortly. For faster assistance, call <a href="tel:${config.tel}"><strong>${config.phoneDisplay}</strong></a>.`,
            () => showOptions([
              { label: `Call ${config.phoneDisplay}`, href: `tel:${config.tel}` },
              { label: "Start New Request", onSelect: start },
              { label: "Close Chat", onSelect: closePanel }
            ])
          );
        } else {
          throw new Error(result.error ?? "send failed");
        }
      } catch {
        botSay(
          `Sorry, something went wrong while sending your request. Please call us directly at <a href="tel:${config.tel}"><strong>${config.phoneDisplay}</strong></a> or email <a href="mailto:${config.email}">${config.email}</a>.`,
          () => showOptions([
            { label: "Try Again", onSelect: submitLead },
            { label: `Call ${config.phoneDisplay}`, href: `tel:${config.tel}` }
          ])
        );
      } finally {
        submitting = false;
        panel.removeAttribute("aria-busy");
      }
    }

    inputRow.addEventListener("submit", (event) => {
      event.preventDefault();
      const step = steps.find((item) => item.key === inputRow.dataset.stepKey) ?? steps[stepIndex];
      if (!step) return;
      const value = (step.multiline ? textareaEl.value : inputEl.value).trim();
      if (!value) return;
      if (step.validate === "phone" && !isValidPhone(value)) {
        botSay("Please enter a valid phone number so our team can contact you.");
        return;
      }
      if (step.validate === "email" && !isValidEmail(value)) {
        botSay("Please enter a valid email address.");
        return;
      }
      answer(step, value);
    });

    textareaEl.addEventListener("keydown", (event) => {
      if (event.key === "Enter" && !event.shiftKey) {
        event.preventDefault();
        inputRow.requestSubmit();
      }
    });

    function openPanel() {
      panel.hidden = false;
      launcher.hidden = true;
      document.body.classList.add("chat-open");
      launcher.setAttribute("aria-expanded", "true");
      if (!opened) {
        opened = true;
        start();
      }
      panel.querySelector<HTMLElement>(".chat-option, input:not([hidden]), textarea:not([hidden])")?.focus();
    }

    function closePanel() {
      panel.hidden = true;
      launcher.hidden = false;
      document.body.classList.remove("chat-open");
      launcher.setAttribute("aria-expanded", "false");
      launcher.focus();
    }

    launcher.addEventListener("click", () => (panel.hidden ? openPanel() : closePanel()));
    closeButton.addEventListener("click", closePanel);
    restartButton.addEventListener("click", start);
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !panel.hidden) closePanel();
    });
  }
</script>

<style is:global>
  .chat-launcher {
    position: fixed;
    right: 18px;
    bottom: 78px;
    z-index: 80;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 2px solid rgba(230, 249, 175, .55);
    cursor: pointer;
    background: linear-gradient(135deg, var(--charcoal-2), var(--charcoal));
    color: var(--white);
    padding: 13px 20px;
    border-radius: 999px;
    box-shadow: 0 12px 28px rgba(13, 6, 48, 0.38);
    font-weight: 900;
    font-size: .95rem;
    transition: transform 160ms cubic-bezier(.23,1,.32,1), box-shadow 160ms ease;
  }
  .chat-launcher svg { color: var(--gold); }
  .chat-launcher:hover, .chat-launcher:focus-visible { transform: translateY(-2px) scale(1.02); box-shadow: 0 16px 34px rgba(13, 6, 48, 0.45); }
  .chat-panel {
    position: fixed;
    right: 18px;
    bottom: 18px;
    z-index: 90;
    width: min(420px, calc(100vw - 24px));
    height: auto;
    max-height: min(680px, calc(100dvh - 36px));
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 16px;
    box-shadow: 0 24px 60px rgba(13, 6, 48, 0.35);
    overflow: hidden;
  }
  .chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    background: linear-gradient(135deg, var(--charcoal-2), var(--charcoal) 70%);
    color: var(--white);
    padding: 14px 16px;
    border-bottom: 2px solid var(--gold);
  }
  .chat-identity { display: flex; align-items: center; gap: 11px; min-width: 0; }
  .chat-avatar {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--lime);
    color: var(--ink);
    font-weight: 900;
    font-size: 1.15rem;
    box-shadow: 0 0 0 2px rgba(255, 255, 255, .18);
  }
  .chat-titles { min-width: 0; }
  .chat-title { margin: 0; color: var(--white); font-weight: 900; line-height: 1.2; }
  .chat-subtitle { margin: 2px 0 0; font-size: .76rem; color: rgba(255, 255, 255, .68); line-height: 1.2; }
  .chat-header-actions { display: flex; align-items: center; gap: 7px; }
  .chat-icon-button {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border: 1px solid rgba(255, 255, 255, .28);
    background: rgba(255, 255, 255, .06);
    color: var(--white);
    border-radius: 50%;
    cursor: pointer;
    transition: background 140ms ease;
  }
  .chat-icon-button:hover, .chat-icon-button:focus-visible { background: rgba(255, 255, 255, .18); }
  .chat-messages {
    flex: 0 1 auto;
    min-height: 150px;
    max-height: 470px;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: var(--paper);
    scrollbar-width: thin;
    scrollbar-color: var(--line) transparent;
  }
  .chat-msg {
    max-width: 85%;
    padding: 11px 15px;
    border-radius: 16px;
    font-size: .93rem;
    line-height: 1.5;
    overflow-wrap: break-word;
    box-shadow: 0 1px 3px rgba(13, 6, 48, .08);
  }
  .chat-msg.bot { background: var(--white); border: 1px solid var(--line); color: var(--ink); border-bottom-left-radius: 5px; align-self: flex-start; }
  .chat-msg.user { background: linear-gradient(135deg, var(--charcoal-2), var(--charcoal)); color: var(--white); border-bottom-right-radius: 5px; align-self: flex-end; }
  .chat-msg.summary { width: 100%; max-width: 100%; }
  .chat-msg a { color: var(--gold-dark); text-decoration: underline; text-underline-offset: 2px; }
  .chat-msg.user a { color: var(--gold); }
  .chat-typing { color: var(--muted); letter-spacing: 3px; }
  @media (prefers-reduced-motion: no-preference) {
    .chat-msg { animation: chat-msg-in 220ms cubic-bezier(.23, 1, .32, 1); }
    @keyframes chat-msg-in {
      from { opacity: 0; transform: translateY(7px); }
      to { opacity: 1; transform: translateY(0); }
    }
  }
  .chat-options {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 4px 16px 14px;
    background: var(--paper);
    max-height: 190px;
    overflow-y: auto;
  }
  .chat-options:empty { padding: 0; }
  .chat-option {
    border: 1.5px solid var(--navy-2);
    background: var(--white);
