---
/**
 * Lightweight estimate CTA.
 * Intentionally a plain link (no Fillout popup script) — the header and footer
 * appear on every page, and loading third-party JS globally was the site's
 * biggest performance problem. The form itself lives on /free-estimate.
 */
interface Props {
  className?: string;
}
const { className = "" } = Astro.props;
---
<div class={`estimate-cta ${className}`}>
  <a class="btn" href="/free-estimate">Request a Free Estimate</a>
</div>

<style>
  .estimate-cta {
    display: inline-flex;
    width: fit-content;
  }
</style>
