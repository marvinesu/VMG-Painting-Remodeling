---
import FooterLeadForm from "./forms/FooterLeadForm.astro";
import { services } from "../data/services";
import { site } from "../data/site";

const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer-top">
    <div>
      <a class="footer-logo" href="/">VMG Painting &amp; Remodeling</a>
      <p class="footer-tagline">Family-owned. Washington-registered. Built on 30+ years of construction experience.</p>
      <div class="footer-cta-row">
        <a class="btn" href="/free-estimate">Request a Free Estimate</a>
        <a class="btn secondary" href={`tel:${site.tel}`}>Call {site.phoneDisplay}</a>
      </div>
    </div>
    {site.footerLeadForm && (
      <div class="footer-lead-wrap">
        <h2 class="footer-lead-heading">Quick Free Estimate</h2>
        <FooterLeadForm />
      </div>
    )}
  </div>
  <div class="container footer-grid">
    <div>
      <h3>About VMG</h3>
      <p>VMG Painting &amp; Remodeling LLC is a family-owned contractor based in Roy, WA, serving homeowners and property owners across Western Washington with interior and exterior painting, siding, roofing, window installation, decks, and remodeling services.</p>
      <p class="footer-license">WA Contractor Registration #{site.license}</p>
    </div>
    <nav aria-label="Footer services">
      <h3>Services</h3>
      {services.map((service) => <a href={`/services/${service.slug}`}>{service.title}</a>)}
    </nav>
    <nav aria-label="Footer company links">
      <h3>Company</h3>
      <a href="/about-us">About Us</a>
      <a href="/services">Our Services</a>
      <a href="/projects">Projects</a>
      <a href="/updates">Updates</a>
      <a href="/contact-us">Contact Us</a>
      <a href="/free-estimate">Free Estimate</a>
    </nav>
    <div>
      <h3>Contact</h3>
      <address>
        <p>{site.name}<br />{site.address}</p>
        <a href={`tel:${site.tel}`}>{site.phoneDisplay}</a>
        <a href="tel:+12069448143">{site.secondaryPhoneDisplay}</a>
        <a href={`mailto:${site.email}`}>{site.email}</a>
      </address>
      <h3 class="footer-areas-heading">Service Areas</h3>
      <p>{site.areas.join(", ")}, WA</p>
    </div>
  </div>
  <div class="container footer-bottom">
    <span>&copy; {year} {site.name}. All rights reserved.</span>
  </div>
</footer>

<style>
  .footer { background: var(--charcoal); color: var(--white); padding: 48px 0 24px; }
  .footer-top { display: grid; grid-template-columns: 1.2fr 1fr; align-items: start; gap: 40px; padding-bottom: 34px; border-bottom: 1px solid rgba(255,255,255,.12); }
  .footer-logo { font-size: 1.35rem; font-weight: 900; }
  .footer-tagline { margin: 8px 0 0; color: rgba(255,255,255,.72); max-width: 520px; }
  .footer-cta-row { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 22px; }
  .footer-cta-row a { margin: 0; }
  .footer-lead-wrap { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); border-radius: var(--radius); padding: clamp(18px, 2.5vw, 26px); }
  .footer-lead-heading { color: var(--white); font-size: 1.2rem; margin-bottom: 14px; }
  .footer-grid { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1.2fr; gap: 34px; padding: 38px 0; }
  .footer h3 { color: var(--white); font-size: 1.05rem; }
  .footer-areas-heading { margin-top: 22px; }
  .footer p, .footer a, .footer-bottom { color: rgba(255,255,255,.72); }
  .footer a { display: block; margin: 9px 0; }
  .footer a:hover, .footer a:focus-visible { color: var(--gold); }
  .footer-license { font-weight: 700; color: rgba(255,255,255,.85); }
  .footer address { font-style: normal; }
  .footer-estimate-button { margin-top: 6px; }
  .footer-bottom { border-top: 1px solid rgba(255,255,255,.12); padding-top: 20px; display: flex; justify-content: space-between; gap: 20px; font-size: .9rem; }
  @media (max-width: 860px) {
    .footer-top { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
    .footer-grid { grid-template-columns: 1fr; gap: 26px; }
  }
</style>
