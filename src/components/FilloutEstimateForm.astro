---
/**
 * FREE ESTIMATE FORM EMBED (lazy-loaded)
 * Used on the home page, service pages, and the Free Estimate page.
 * The Fillout script loads only on user intent (scroll-near or click) so the
 * ~4MB third-party payload never blocks initial page load.
 * To swap in a new embed, update the formId below.
 *
 * trigger="click" makes the form load ONLY when "Start Form" is clicked —
 * used on the home page to keep it as light as possible.
 */
import LazyFilloutEmbed from "./LazyFilloutEmbed.astro";

interface Props {
  trigger?: "visible" | "click";
}
const { trigger = "visible" } = Astro.props;
---
<LazyFilloutEmbed formId="xeVye6EX7Mus" trigger={trigger} heading="Free Estimate Request" />
