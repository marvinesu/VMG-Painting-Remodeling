---
/**
 * Performance-friendly Fillout embed.
 *
 * The third-party Fillout script (~4MB of JS) is NOT loaded on initial page
 * load. It loads only when:
 *   - the visitor clicks "Start Form", or
 *   - trigger="visible": the visitor scrolls within 400px of the form.
 *
 * To swap in a new embed, change the formId prop where this component is used
 * (FilloutContactForm.astro / FilloutEstimateForm.astro).
 */
import { site } from "../data/site";

interface Props {
  formId: string;
  /** "visible" loads on scroll-near or click; "click" loads only on click. */
  trigger?: "visible" | "click";
  heading?: string;
}
const { formId, trigger = "visible", heading = "Free Estimate Request" } = Astro.props;
---
<div class="lazy-fillout" data-fillout-form-id={formId} data-trigger={trigger}>
  <div class="fillout-intro">
    <h3>{heading}</h3>
    <p>Takes about a minute. No obligation, no pressure.</p>
    <button type="button" class="btn fillout-start">Start Form</button>
    <p class="note fillout-fallback">
      Prefer to talk? Call <a href={`tel:${site.tel}`}>{site.phoneDisplay}</a> or email
      <a href={`mailto:${site.email}`}>{site.email}</a>.
    </p>
  </div>
  <p class="fillout-loading" hidden>Loading secure form&hellip;</p>
  <div class="fillout-target"></div>
</div>

<script>
  const FILLOUT_SRC = "https://server.fillout.com/embed/v1/";

  function loadEmbed(container: HTMLElement) {
    if (container.dataset.loaded === "true") return;
    container.dataset.loaded = "true";

    const intro = container.querySelector<HTMLElement>(".fillout-intro");
    const loading = container.querySelector<HTMLElement>(".fillout-loading");
    const target = container.querySelector<HTMLElement>(".fillout-target");
    if (!target) return;

    intro?.setAttribute("hidden", "");
    loading?.removeAttribute("hidden");

    const embed = document.createElement("div");
    embed.setAttribute("data-fillout-id", container.dataset.filloutFormId ?? "");
    embed.setAttribute("data-fillout-embed-type", "standard");
    embed.setAttribute("data-fillout-inherit-parameters", "");
    embed.setAttribute("data-fillout-dynamic-resize", "");
    embed.style.width = "100%";
    embed.style.minHeight = "460px";
    target.appendChild(embed);

    if (!document.querySelector(`script[src="${FILLOUT_SRC}"]`)) {
      const script = document.createElement("script");
      script.src = FILLOUT_SRC;
      script.async = true;
      document.body.appendChild(script);
    }

    const watcher = window.setInterval(() => {
      if (embed.querySelector("iframe")) {
        loading?.setAttribute("hidden", "");
        window.clearInterval(watcher);
      }
    }, 250);
    window.setTimeout(() => window.clearInterval(watcher), 20000);
  }

  document.querySelectorAll<HTMLElement>(".lazy-fillout").forEach((container) => {
    container
      .querySelector<HTMLButtonElement>(".fillout-start")
      ?.addEventListener("click", () => loadEmbed(container));

    if (container.dataset.trigger === "visible" && "IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            observer.disconnect();
            loadEmbed(container);
          }
        },
        { rootMargin: "400px 0px" }
      );
      observer.observe(container);
    }
  });
</script>

<style>
  /* Reserve space so loading the embed never shifts the layout. */
  .lazy-fillout { width: 100%; min-height: 460px; }
  .fillout-intro h3 { margin-bottom: 8px; }
  .fillout-intro p { margin-bottom: 14px; }
  .fillout-start { margin-bottom: 14px; }
  .fillout-fallback a { color: var(--gold-dark); font-weight: 800; text-decoration: underline; }
  .fillout-loading { font-weight: 700; }
</style>
