---
interface Props { title?: string; text?: string; }
const { title = "Ready to Improve Your Home?", text = "From painting to remodeling, VMG Painting & Remodeling LLC helps you improve your home with skilled workmanship and honest communication." } = Astro.props;
---
<section class="section dark cta-band">
  <div class="container cta-inner">
    <div>
      <span class="eyebrow">Request Your Quote</span>
      <h2>{title}</h2>
      <p>{text}</p>
    </div>
    <div class="button-row">
      <a class="btn" href="/free-estimate">Get a Free Estimate</a>
      <a class="btn secondary" href="tel:+12537544871">Call Now</a>
    </div>
  </div>
</section>
<style>
  .cta-inner { display: flex; justify-content: space-between; gap: 30px; align-items: center; }
  .cta-inner p { max-width: 650px; }
  @media (max-width: 760px) { .cta-inner { display: block; } }
</style>
