---
import { site } from "../data/site";

interface Props {
  title?: string;
  text?: string;
}
const {
  title = "Ready to Improve Your Home?",
  text = "From a fresh coat of paint to a full remodel, VMG Painting & Remodeling LLC helps Western Washington homeowners get the job done right — with skilled workmanship and honest communication."
} = Astro.props;
---
<section class="section dark cta-band">
  <div class="container cta-inner">
    <div>
      <span class="eyebrow">Free Estimate</span>
      <h2>{title}</h2>
      <p>{text}</p>
    </div>
    <div class="button-row">
      <a class="btn" href="/free-estimate">Get a Free Estimate</a>
      <a class="btn secondary" href={`tel:${site.tel}`}>Call {site.phoneDisplay}</a>
    </div>
  </div>
</section>
<style>
  .cta-inner { display: flex; justify-content: space-between; gap: 30px; align-items: center; }
  .cta-inner p { max-width: 650px; margin-bottom: 0; }
  .cta-inner .button-row { flex-shrink: 0; margin-top: 0; }
  @media (max-width: 760px) {
    .cta-inner { display: block; }
    .cta-inner .button-row { margin-top: var(--space-lg); }
  }
</style>
