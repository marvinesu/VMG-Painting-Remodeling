---
import EstimateCtaButton from "./EstimateCtaButton.astro";
import { services } from "../data/services";
import { navItems, site } from "../data/site";

const primaryNav = navItems.filter((item) => item.label !== "Services");
---
<header class="site-header">
  <div class="topbar">
    <div class="container topbar-inner">
      <a href={`mailto:${site.email}`}>{site.email}</a>
      <span>{site.address}</span>
      <a href={`tel:${site.tel}`}>Call {site.phoneDisplay}</a>
    </div>
  </div>
  <nav class="nav container" aria-label="Primary navigation">
    <a class="logo" href="/" aria-label="VMG Painting & Remodeling home">VMG Painting <span>&amp; Remodeling</span></a>
    <button class="menu-button" type="button" aria-expanded="false" aria-controls="site-nav-links">
      <span class="menu-icon" aria-hidden="true"></span>
      Menu
    </button>
    <div class="nav-links" id="site-nav-links">
      {primaryNav.slice(0, 2).map((item) => <a href={item.href}>{item.label}</a>)}
      <details class="services-menu">
        <summary>Services</summary>
        <div class="services-panel">
          <a class="all-services" href="/services">All Services</a>
          {services.map((service) => <a href={`/services/${service.slug}`}>{service.title}</a>)}
        </div>
      </details>
      {primaryNav.slice(2).map((item) => <a href={item.href}>{item.label}</a>)}
      <a class="nav-phone" href={`tel:${site.tel}`}>{site.phoneDisplay}</a>
      <EstimateCtaButton className="nav-cta-wrap" />
    </div>
  </nav>
</header>

<script>
  const button = document.querySelector<HTMLButtonElement>(".menu-button");
  const links = document.getElementById("site-nav-links");
  button?.addEventListener("click", () => {
    const open = button.getAttribute("aria-expanded") === "true";
    button.setAttribute("aria-expanded", String(!open));
    links?.classList.toggle("open", !open);
    document.body.classList.toggle("mobile-menu-open", !open);
  });
  links?.querySelectorAll("a").forEach((link) => link.addEventListener("click", () => {
    button?.setAttribute("aria-expanded", "false");
    links.classList.remove("open");
    document.body.classList.remove("mobile-menu-open");
  }));
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && button?.getAttribute("aria-expanded") === "true") {
      button.setAttribute("aria-expanded", "false");
      links?.classList.remove("open");
      document.body.classList.remove("mobile-menu-open");
      button.focus();
    }
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.92);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
    transition: box-shadow 220ms ease;
  }
  .site-header.scrolled { box-shadow: 0 10px 30px rgba(13, 6, 48, 0.10); }
  .topbar { background: linear-gradient(90deg, var(--ink), var(--navy)); color: rgba(255,255,255,.85); font-size: .86rem; }
  .topbar-inner { min-height: 38px; display: flex; gap: 22px; align-items: center; justify-content: space-between; }
  .topbar a:hover, .topbar a:focus-visible { color: var(--lime); }
  .nav { min-height: 76px; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
  .logo { font-size: 1.16rem; font-weight: 700; font-family: var(--font-heading); color: var(--ink); max-width: 270px; line-height: 1.15; }
  .logo span { color: var(--navy-2); }
  .nav-links { display: flex; align-items: center; gap: 18px; font-weight: 800; font-size: .92rem; }
  .nav-links a:hover, .nav-links a:focus-visible { color: var(--gold-dark); }
  .nav-phone { white-space: nowrap; }
  .nav-cta-wrap { align-items: center; }
  .services-menu { position: relative; }
  .services-menu summary { list-style: none; cursor: pointer; }
  .services-menu summary::-webkit-details-marker { display: none; }
  .services-menu summary::after { content: ""; display: inline-block; width: 7px; height: 7px; margin-left: 7px; border-right: 2px solid currentColor; border-bottom: 2px solid currentColor; transform: translateY(-2px) rotate(45deg); transition: transform 160ms cubic-bezier(.23,1,.32,1); }
  .services-menu[open] summary::after { transform: translateY(1px) rotate(225deg); }
  .services-panel { position: absolute; top: calc(100% + 18px); left: -18px; width: 310px; padding: 10px; border: 1px solid var(--line); border-radius: 12px; background: var(--white); box-shadow: 0 18px 40px rgba(13,6,48,.16); display: grid; gap: 2px; z-index: 70; }
  .services-panel a { margin: 0; padding: 10px 12px; border-radius: 8px; line-height: 1.2; color: var(--ink); }
  .services-panel a:hover, .services-panel a:focus-visible { background: var(--cream); color: var(--ink); }
  .services-panel .all-services { color: var(--gold-dark); }
  .menu-button { display: none; }
  @media (max-width: 920px) {
    .site-header { position: static; -webkit-backdrop-filter: none; backdrop-filter: none; }
    .topbar-inner { justify-content: center; }
    .topbar-inner span, .topbar-inner a:last-child { display: none; }
    .topbar-inner a:first-child { display: block; max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: .78rem; }
    .menu-button {
      display: inline-flex;
      position: fixed;
      left: 12px;
      bottom: max(12px, env(safe-area-inset-bottom));
      z-index: 82;
      align-items: center;
      gap: 9px;
      background: var(--lime);
      color: var(--ink);
      border: 0;
      border-radius: 999px;
      padding: 10px 16px;
      font-weight: 900;
      cursor: pointer;
    }
    .menu-icon { display: inline-block; width: 16px; height: 2px; background: currentColor; position: relative; }
    .menu-icon::before, .menu-icon::after { content: ""; position: absolute; left: 0; width: 16px; height: 2px; background: currentColor; }
    .menu-icon::before { top: -5px; }
    .menu-icon::after { top: 5px; }
    .nav { min-height: 68px; }
    .nav-links {
      display: none;
      position: fixed;
      left: 12px;
      bottom: calc(max(12px, env(safe-area-inset-bottom)) + 58px);
      z-index: 81;
      width: min(340px, calc(100vw - 24px));
      max-height: calc(100dvh - 100px);
      overflow-y: auto;
      flex-direction: column;
      align-items: stretch;
      gap: 4px;
      padding: 16px;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: var(--white);
      box-shadow: 0 18px 44px rgba(13, 6, 48, .28);
    }
    .nav-links.open { display: flex; }
    .nav-links a { padding: 10px 12px; border-radius: 8px; }
    .nav-links a:hover, .nav-links a:focus-visible { background: var(--cream); }
    .services-panel { position: static; width: 100%; margin-top: 8px; box-shadow: none; }
    .services-panel a { padding: 11px 12px; }
    .nav-phone { padding: 10px 0; }
    .nav-cta-wrap { width: 100%; justify-content: center; }
    :global(body.chat-open) .menu-button,
    :global(body.chat-open) .nav-links { opacity: 0; pointer-events: none; }
  }
  @media (prefers-reduced-motion: no-preference) and (max-width: 920px) {
    .nav-links.open { animation: mobile-menu-in 220ms cubic-bezier(.23,1,.32,1); }
    @keyframes mobile-menu-in {
      from { opacity: 0; transform: translateY(14px); }
      to { opacity: 1; transform: translateY(0); }
    }
  }
</style>
