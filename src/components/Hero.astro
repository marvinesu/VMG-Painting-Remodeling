---
interface Props {
  eyebrow: string;
  title: string;
  text: string;
  image: string;
  imageAlt?: string;
  primaryHref?: string;
  secondaryHref?: string;
}
const { eyebrow, title, text, image, imageAlt = "", primaryHref = "/free-estimate", secondaryHref = "/services" } = Astro.props;
---
<section class="hero">
  <div class="hero-bg"><img src={image} alt={imageAlt} width="1600" height="1000" fetchpriority="high" decoding="async" /></div>
  <div class="container hero-inner">
    <span class="eyebrow">{eyebrow}</span>
    <h1>{title}</h1>
    <p class="lead">{text}</p>
    <div class="button-row">
      <a class="btn" href={primaryHref}>Get a Free Estimate</a>
      <a class="btn secondary" href={secondaryHref}>View Our Services</a>
    </div>
    <p class="hero-areas">Serving Thurston, Pierce, King &amp; Snohomish County, WA</p>
  </div>
</section>

<style>
  .hero { min-height: 700px; position: relative; display: grid; align-items: center; color: var(--white); overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; background: var(--charcoal); }
  .hero-bg::after { content: ""; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(31,27,20,.88), rgba(31,27,20,.52), rgba(31,27,20,.25)); }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .hero-inner { position: relative; padding: 110px 0 72px; }
  .hero-areas { margin: 22px 0 0; font-weight: 700; color: rgba(255,255,255,.85); font-size: .95rem; letter-spacing: .02em; }
  @media (max-width: 720px) { .hero { min-height: 600px; } .hero-bg::after { background: rgba(31,27,20,.76); } }
</style>
