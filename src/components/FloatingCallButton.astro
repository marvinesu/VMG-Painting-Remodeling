---
import { site } from "../data/site";
---
<a class="floating-call" href={`tel:${site.tel}`} aria-label={`Call VMG Painting & Remodeling at ${site.phoneDisplay}`}>
  Call Now
</a>
<style>
  .floating-call { position: fixed; right: 18px; bottom: 18px; z-index: 60; background: var(--gold); color: #1f1a12; padding: 13px 18px; border-radius: 999px; box-shadow: var(--shadow); font-weight: 900; }
</style>
