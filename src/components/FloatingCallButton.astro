---
import { site } from "../data/site";
---
<a class="floating-call" href={`tel:${site.tel}`} aria-label={`Call VMG Painting & Remodeling at ${site.phoneDisplay}`}>
  <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
    <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.4 21 3 13.6 3 4.5a1 1 0 0 1 1-1H7.5a1 1 0 0 1 1 1c0 1.24.2 2.45.57 3.57a1 1 0 0 1-.24 1.02l-2.21 2.2z"/>
  </svg>
  <span>Call Now</span>
</a>
<style>
  .floating-call {
    position: fixed;
    right: 18px;
    bottom: 18px;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--lime);
    color: var(--ink);
    padding: 13px 20px;
    border-radius: 999px;
    box-shadow: 0 10px 24px rgba(13, 6, 48, 0.32);
    font-weight: 900;
    transition: transform 160ms cubic-bezier(.23,1,.32,1), background 160ms ease;
  }
  .floating-call:hover, .floating-call:focus-visible { transform: translateY(-2px); background: #d8f095; }
  :global(body.chat-open) .floating-call { opacity: 0; pointer-events: none; transform: translateY(12px); }
  @media (max-width: 520px) {
    .floating-call {
      right: 12px;
      bottom: 12px;
      width: 52px;
      height: 52px;
      justify-content: center;
      padding: 0;
    }
    .floating-call span { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; }
  }
</style>
