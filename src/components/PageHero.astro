---
import { srcsetFor } from "../data/images";

interface Props {
  title: string;
  text?: string;
  image?: string;
  /** Optional breadcrumb trail rendered above the H1 (last item is the current page). */
  crumbs?: { label: string; href?: string }[];
}
const { title, text = "", image, crumbs = [] } = Astro.props;
---
<section class="page-hero">
  {image && (
    <img
      class="page-hero-bg"
      src={image}
      srcset={srcsetFor(image)}
      sizes="100vw"
      alt=""
      width="1440"
      height="960"
      fetchpriority="high"
      decoding="async"
    />
  )}
  <div class="container page-hero-content">
    {crumbs.length > 0 && (
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol>
          {crumbs.map((crumb) => (
            <li>{crumb.href ? <a href={crumb.href}>{crumb.label}</a> : <span aria-current="page">{crumb.label}</span>}</li>
          ))}
        </ol>
      </nav>
    )}
    <span class="eyebrow">VMG Painting &amp; Remodeling</span>
    <h1>{title}</h1>
    {text && <p class="lead">{text}</p>}
  </div>
</section>

<style>
  .page-hero { position: relative; overflow: hidden; }
  .page-hero-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  /* Dark overlay keeps text contrast identical to the old CSS-background version. */
  .page-hero::after { content: ""; position: absolute; inset: 0; background: rgba(34, 29, 21, .78); }
  .page-hero-content { position: relative; z-index: 1; }
</style>
