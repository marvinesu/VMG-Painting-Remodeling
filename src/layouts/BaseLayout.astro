---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FloatingCallButton from "../components/FloatingCallButton.astro";
import ChatbotWidget from "../components/chatbot/ChatbotWidget.astro";
import EstimatePopup from "../components/EstimatePopup.astro";
import VoucherBanner from "../components/VoucherBanner.astro";
import { site } from "../data/site";
import { srcsetFor } from "../data/images";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  /** Additional JSON-LD objects (Service, FAQPage, BreadcrumbList, …) rendered alongside the LocalBusiness schema. */
  schema?: object[];
  /** Hero/LCP image to preload with responsive hints (path under /images). */
  preloadImage?: string;
  /** Extra origins to preconnect to when a page depends on one. */
  preconnect?: string[];
}

const {
  title,
  description,
  path = "/",
  image = "/images/painting-exterior-residential.webp",
  schema = [],
  preloadImage,
  preconnect = []
} = Astro.props;
const canonical = new URL(path, site.url).toString();
const ogImage = new URL(image, site.url).toString();

const businessSchema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "@id": `${site.url}/#business`,
  name: site.name,
  url: site.url,
  telephone: site.tel,
  email: site.email,
  image: ogImage,
  address: {
    "@type": "PostalAddress",
    streetAddress: "8517 311th St S",
    addressLocality: "Roy",
    addressRegion: "WA",
    postalCode: "98580",
    addressCountry: "US"
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: site.geo.latitude,
    longitude: site.geo.longitude
  },
  areaServed: site.areas.map((area) => ({ "@type": "AdministrativeArea", name: `${area}, WA` })),
  identifier: `WA Contractor Registration #${site.license}`,
  founder: { "@type": "Person", name: site.owner },
  knowsAbout: [
    "Interior painting",
    "Exterior painting",
    "Siding installation",
    "Roofing",
    "Window installation",
    "Deck building",
    "Home remodeling"
  ]
};

const jsonLd = [businessSchema, ...schema];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#18314f" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lexend:wght@600;700&display=swap" />
    {preloadImage && (
      <link
        rel="preload"
        as="image"
        href={preloadImage}
        imagesrcset={srcsetFor(preloadImage)}
        imagesizes="100vw"
        fetchpriority="high"
      />
    )}
    {preconnect.map((origin) => <link rel="preconnect" href={origin} crossorigin />)}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {jsonLd.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <FloatingCallButton />
    <ChatbotWidget />
    <EstimatePopup />
    <VoucherBanner />
    <script>
      import "../scripts/motion";
    </script>
  </body>
</html>
